{
  "name": "petchr",
  "version": "1.2.0",
  "description": "A zero-dependency, TypeScript-native fetch wrapper with retry, timeout, and rate-limit handling",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "fetch",
    "http",
    "client",
    "retry",
    "timeout",
    "rate-limit",
    "typescript",
    "zero-dependency"
  ],
  "author": "eritrouib",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "jest-environment-node": "^29.7.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/petchr.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/petchr/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/petchr#readme"
}
